# Shared
NODE_ENV=development

# API
API_PORT=xxxx
API_BASE_URL=http://localhost:xxxx
WEB_ORIGIN=http://localhost:xxxx
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=7d

# Database
MONGODB_URI=mongodb+srv://username:password@cluster-name.xxxxx.mongodb.net/database_name?retryWrites=true&w=majority


# Redis / Queue
REDIS_URL=redis://default:password@example.upstash.io:6379

# AI
GROQ_API_KEY=
GROQ_MODEL=

# Search
TAVILY_API_KEY=
SERPER_API_KEY=

# Storage
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
LOCAL_UPLOAD_DIR=uploads
